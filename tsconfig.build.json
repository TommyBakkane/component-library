{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": ["src"],
  "exclude": [
    "src/App.tsx",
    "src/App.css",
    "src/main.tsx",
    "src/index.css",
    "src/previews",
    "src/stories",
    "**/*.stories.tsx",
    "**/*.stories.ts"
  ]
}
